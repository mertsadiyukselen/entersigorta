generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Application {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model JobListing {
  id           Int      @id @default(autoincrement())
  title        String
  location     String
  type         String
  department   String
  description  String
  requirements String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Banner {
  id               Int      @id @default(autoincrement())
  title            String
  subtitle         String?
  description      String?
  imageUrl         String
  primaryCtaText   String?
  primaryCtaHref   String?
  secondaryCtaText String?
  secondaryCtaHref String?
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PartnerLogo {
  id        Int      @id @default(autoincrement())
  name      String
  imageUrl  String
  linkUrl   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GuideArticle {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  excerpt     String?
  category    String
  body        String
  publishedAt DateTime @default(now())
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
